{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WaveDance",
  "version": "0.1.0",
  "identifier": "com.wavedance.desktop",
  "build": {
    "beforeDevCommand": "if [ -d frontend ]; then cd frontend; else cd ../frontend; fi && npm run dev",
    "beforeBuildCommand": "if [ -d frontend ]; then cd frontend; else cd ../frontend; fi && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "WaveDance",
        "width": 1080,
        "height": 680,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true
      },
      {
        "label": "settings",
        "title": "WaveDance 设置",
        "url": "settings.html",
        "width": 620,
        "height": 760,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**", "$APPCACHE/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": ["resources/blackhole/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  }
}
